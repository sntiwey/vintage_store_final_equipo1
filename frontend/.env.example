# ============================================================
#  Variables de entorno — La Boutique Vintage
#  Renombra este archivo a .env y agrega tus keys reales
# ============================================================

# Google OAuth (para login/registro con Google)
# Obtén tu Client ID en: https://console.cloud.google.com
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# → Authorized origins: http://localhost:3000
VITE_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID_AQUI

# Google Maps / Places (para autocompletado de dirección)
# Misma consola → Enable "Maps JavaScript API" y "Places API"
VITE_GOOGLE_MAPS_KEY=TU_GOOGLE_MAPS_KEY_AQUI
